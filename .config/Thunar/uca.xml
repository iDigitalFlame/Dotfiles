<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>cacher</icon>
	<name>Open Terminal</name>
	<submenu></submenu>
	<unique-id>OpenTerminal</unique-id>
	<command>/usr/bin/kitty --single-instance --instance-group sway %f</command>
	<description>Open a Terminal Here</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>accessories-text-editor</icon>
	<name>Open in Leafpad</name>
	<submenu></submenu>
	<unique-id>OpenLeafpad-2</unique-id>
	<command>/usr/bin/leafpad %f</command>
	<description>Open in Leafpad</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<other-files/>
	<text-files/>
</action>
</actions>